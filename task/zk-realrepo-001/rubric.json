[
  {
    "id": "ZKU001",
    "layer": "unit",
    "category": "notebook_lifecycle",
    "requirement_refs": ["REQ-notebook"],
    "description": "Init creates notebook control files.",
    "weight": 4,
    "steps": [{"args": ["init", "{nb}"]}],
    "checks": {"files_exist": ["{nb}/.zk", "{nb}/.zk/config.toml", "{nb}/.zk/templates"]}
  },
  {
    "id": "ZKU002",
    "layer": "unit",
    "category": "notebook_lifecycle",
    "requirement_refs": ["REQ-notebook"],
    "description": "Notebook discovery uses cwd, environment variable, and global flag precedence.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/a.md": "# Primary\n",
      "{other}/.zk/config.toml": "",
      "{other}/b.md": "# Other\n"
    },
    "steps": [
      {"args": ["list", "--format", "path"], "cwd": "{nb}/sub/deep"},
      {"args": ["list", "--format", "path"], "cwd": "{tmp}", "env": {"ZK_NOTEBOOK_DIR": "{other}"}},
      {"args": ["--notebook-dir", "{nb}", "list", "--format", "path"], "cwd": "{tmp}", "env": {"ZK_NOTEBOOK_DIR": "{other}"}}
    ],
    "checks": {
      "dirs_exist": ["{nb}/sub/deep"],
      "step_stdout_contains": {"0": ["a.md"], "1": ["b.md"], "2": ["a.md"]},
      "step_stdout_forbidden": {"0": ["b.md"], "1": ["a.md"], "2": ["b.md"]}
    }
  },
  {
    "id": "ZKU003",
    "layer": "unit",
    "category": "note_creation",
    "requirement_refs": ["REQ-new-note"],
    "description": "New note with explicit id, title, directory, print-path, and stdin body creates content.",
    "weight": 4,
    "setup_files": {"{nb}/.zk/config.toml": ""},
    "steps": [
      {"args": ["--notebook-dir", "{nb}", "new", "--id", "abc1", "--title", "Graph Theory", "--dir", "math", "--print-path", "--interactive"], "stdin": "Body about nodes and edges."}
    ],
    "checks": {
      "stdout_contains": ["math", "abc1", "graph-theory.md"],
      "files_exist": ["{nb}/math/abc1-graph-theory.md"],
      "files_contain": {"{nb}/math/abc1-graph-theory.md": ["Graph Theory", "Body about nodes and edges."]}
    }
  },
  {
    "id": "ZKU004",
    "layer": "unit",
    "category": "note_creation",
    "requirement_refs": ["REQ-new-note", "REQ-errors"],
    "description": "Duplicate explicit note output path fails without overwriting existing content.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/same.md": "# Existing\nkeep me\n"
    },
    "steps": [
      {"args": ["--notebook-dir", "{nb}", "new", "--filename", "same.md", "--title", "Replacement"], "allow_error": true}
    ],
    "checks": {
      "expect_error": true,
      "stderr_contains_any": ["exists", "duplicate", "overwrite"],
      "files_contain": {"{nb}/same.md": ["# Existing", "keep me"]}
    }
  },
  {
    "id": "ZKU005",
    "layer": "unit",
    "category": "note_parsing",
    "requirement_refs": ["REQ-note-parse", "REQ-tags", "REQ-links"],
    "description": "List JSON parses frontmatter title, tags, wiki links, Markdown links, and word count.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/alpha.md": "---\ntitle: Alpha Note\ntags: [math, inbox]\n---\n# Ignored Heading\nSee [Beta](beta.md) and [[Gamma Note]].\n"
    },
    "steps": [{"args": ["--notebook-dir", "{nb}", "list", "--format", "json"]}],
    "checks": {
      "json_notes": {"expected": [{"path": "alpha.md", "title": "Alpha Note", "tags": ["math", "inbox"], "links_any": ["beta.md", "Gamma Note"], "min_word_count": 5}]}
    }
  },
  {
    "id": "ZKU006",
    "layer": "unit",
    "category": "note_parsing",
    "requirement_refs": ["REQ-note-parse"],
    "description": "Title fallback uses first heading and then filename stem.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/heading.md": "# Heading Title\nBody\n",
      "{nb}/plain-note.md": "Body without heading.\n"
    },
    "steps": [{"args": ["--notebook-dir", "{nb}", "list", "--format", "json"]}],
    "checks": {
      "json_notes": {"expected": [{"path": "heading.md", "title": "Heading Title"}, {"path": "plain-note.md", "title": "plain-note"}]}
    }
  },
  {
    "id": "ZKU007",
    "layer": "unit",
    "category": "tag_semantics",
    "requirement_refs": ["REQ-tags"],
    "description": "Tag listing combines YAML tags, keywords, hashtags, and colon tags.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "[format.markdown]\ncolon_tags = true\n",
      "{nb}/a.md": "---\nkeywords: [research]\n---\n# A\n#inbox :project/ai:\n",
      "{nb}/b.md": "---\ntags: [inbox]\n---\n# B\n#done\n"
    },
    "steps": [{"args": ["--notebook-dir", "{nb}", "tag", "list", "--format", "json"]}],
    "checks": {"json_tags": {"expected_counts": {"inbox": 2, "research": 1, "project/ai": 1, "done": 1}}}
  },
  {
    "id": "ZKU008",
    "layer": "unit",
    "category": "tag_semantics",
    "requirement_refs": ["REQ-tags", "REQ-list-filters"],
    "description": "Tag expressions support OR and NOT filters.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/a.md": "# A\n#inbox #todo\n",
      "{nb}/b.md": "# B\n#inbox #done\n",
      "{nb}/c.md": "# C\n#later\n"
    },
    "steps": [{"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--tag", "inbox OR later, NOT done"]}],
    "checks": {"stdout_contains": ["a.md", "c.md"], "stdout_forbidden": ["b.md"]}
  },
  {
    "id": "ZKU009",
    "layer": "unit",
    "category": "link_semantics",
    "requirement_refs": ["REQ-links"],
    "description": "Direct link-to and linked-by filters resolve Markdown and wiki links.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/alpha.md": "# Alpha\nLinks to [Beta](beta.md) and [[Gamma]].\n",
      "{nb}/beta.md": "# Beta\n",
      "{nb}/gamma.md": "# Gamma\n"
    },
    "steps": [
      {"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--link-to", "beta.md"]},
      {"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--linked-by", "alpha.md"]}
    ],
    "checks": {
      "step_stdout_contains": {"0": ["alpha.md"], "1": ["beta.md", "gamma.md"]},
      "step_stdout_forbidden": {"0": ["beta.md", "gamma.md"]}
    }
  },
  {
    "id": "ZKU010",
    "layer": "unit",
    "category": "link_semantics",
    "requirement_refs": ["REQ-links", "REQ-list-filters"],
    "description": "Recursive linked-by traversal honors max-distance.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/a.md": "# A\n[[B]]\n",
      "{nb}/b.md": "# B\n[[C]]\n",
      "{nb}/c.md": "# C\n[[D]]\n",
      "{nb}/d.md": "# D\n"
    },
    "steps": [{"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--linked-by", "a.md", "--recursive", "--max-distance", "2"]}],
    "checks": {"stdout_contains": ["b.md", "c.md"], "stdout_forbidden": ["d.md"]}
  },
  {
    "id": "ZKU011",
    "layer": "unit",
    "category": "list_filters",
    "requirement_refs": ["REQ-list-filters"],
    "description": "Repeated exact matches, exclude prefixes, and limit compose in list output.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/work/a.md": "# Alpha\nPizza mushrooms planning #recipe #work\n",
      "{nb}/work/b.md": "# Beta\nPizza pineapple planning #recipe #work\n",
      "{nb}/archive/c.md": "# Gamma\nPizza mushrooms archive #recipe #work\n"
    },
    "steps": [{"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--match-strategy", "exact", "--match", "Pizza", "--match", "mushrooms", "--exclude", "archive", "--limit", "1"]}],
    "checks": {"stdout_contains": ["work/a.md"], "stdout_forbidden": ["work/b.md", "archive/c.md"]}
  },
  {
    "id": "ZKU012",
    "layer": "unit",
    "category": "list_sorting",
    "requirement_refs": ["REQ-list-filters"],
    "description": "Path descending sort suffix orders path output deterministically.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/a.md": "# A\n",
      "{nb}/z.md": "# Z\n",
      "{nb}/m.md": "# M\n"
    },
    "steps": [{"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--sort", "path-"]}],
    "checks": {"stdout_contains": ["z.md", "m.md", "a.md"], "stdout_order": ["z.md", "m.md", "a.md"]}
  },
  {
    "id": "ZKU013",
    "layer": "unit",
    "category": "list_sorting",
    "requirement_refs": ["REQ-list-filters", "REQ-note-parse"],
    "description": "Word-count descending sort uses parsed note body size.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/short.md": "# Short\none\n",
      "{nb}/long.md": "# Long\none two three four five\n",
      "{nb}/mid.md": "# Mid\none two three\n"
    },
    "steps": [{"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--sort", "word-count-"]}],
    "checks": {"stdout_contains": ["long.md", "mid.md", "short.md"], "stdout_order": ["long.md", "mid.md", "short.md"]}
  },
  {
    "id": "ZKU014",
    "layer": "unit",
    "category": "graph",
    "requirement_refs": ["REQ-graph", "REQ-links"],
    "description": "Graph JSON emits nodes and edges for linked notes.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/root.md": "# Root\n[[Branch]]\n",
      "{nb}/branch.md": "# Branch\n"
    },
    "steps": [{"args": ["--notebook-dir", "{nb}", "graph", "--format", "json"]}],
    "checks": {"step_json_graph": {"0": {"nodes": ["root.md", "branch.md"], "edges": [["root.md", "branch.md"]]}}}
  },
  {
    "id": "ZKU015",
    "layer": "unit",
    "category": "errors",
    "requirement_refs": ["REQ-errors"],
    "description": "Invalid regex match fails with useful stderr.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/a.md": "# A\n"
    },
    "steps": [{"args": ["--notebook-dir", "{nb}", "list", "--match-strategy", "re", "--match", "["], "allow_error": true}],
    "checks": {"expect_error": true, "stderr_contains_any": ["regex", "pattern", "invalid", "unterminated", "character set"]}
  },
  {
    "id": "ZKU016",
    "layer": "unit",
    "category": "errors",
    "requirement_refs": ["REQ-errors"],
    "description": "List outside a notebook fails clearly.",
    "weight": 4,
    "steps": [{"args": ["list"], "cwd": "{tmp}", "allow_error": true}],
    "checks": {"expect_error": true, "stderr_contains_any": ["notebook", ".zk"]}
  },
  {
    "id": "ZKU017",
    "layer": "unit",
    "category": "config",
    "requirement_refs": ["REQ-config", "REQ-list-filters"],
    "description": "Named config filters apply tag and exclude defaults to list output.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "[filter.work]\ntag = \"work\"\nexclude = \"archive\"\n",
      "{nb}/work/a.md": "# Work A\n#work planning\n",
      "{nb}/archive/b.md": "# Archived Work\n#work old\n",
      "{nb}/personal.md": "# Personal\n#home notes\n"
    },
    "steps": [{"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--filter", "work"]}],
    "checks": {"stdout_contains": ["work/a.md"], "stdout_forbidden": ["archive/b.md", "personal.md"]}
  },
  {
    "id": "ZKU018",
    "layer": "unit",
    "category": "config",
    "requirement_refs": ["REQ-config", "REQ-new-note"],
    "description": "Config note defaults drive new-note title and filename template rendering.",
    "weight": 4,
    "setup_files": {
      "{nb}/.zk/config.toml": "[note]\ndefault_title = \"Untitled Task\"\nfilename = \"{{id}}-{{slug title}}\"\n"
    },
    "steps": [{"args": ["--notebook-dir", "{nb}", "new", "--id", "cfg1", "--print-path"]}],
    "checks": {
      "stdout_contains": ["cfg1-untitled-task.md"],
      "files_exist": ["{nb}/cfg1-untitled-task.md"],
      "files_contain": {"{nb}/cfg1-untitled-task.md": ["# Untitled Task"]}
    }
  },
  {
    "id": "ZKS001",
    "layer": "system",
    "system_dimension": "cross_feature_dataflow",
    "category": "new_tag_graph",
    "requirement_refs": ["REQ-new-note", "REQ-tags", "REQ-links", "REQ-graph"],
    "description": "Newly created notes feed tag discovery and graph edge output.",
    "weight": 8,
    "steps": [
      {"args": ["init", "{nb}"]},
      {"args": ["--notebook-dir", "{nb}", "new", "--id", "n1", "--title", "Root Idea", "--filename", "n1-root.md", "--interactive"], "stdin": "# Root Idea\n#seed Links to [[Branch Idea]].\n"},
      {"args": ["--notebook-dir", "{nb}", "new", "--id", "n2", "--title", "Branch Idea", "--filename", "n2-branch.md", "--interactive"], "stdin": "# Branch Idea\n#seed Details.\n"},
      {"args": ["--notebook-dir", "{nb}", "tag", "list", "--format", "json"]},
      {"args": ["--notebook-dir", "{nb}", "graph", "--format", "json", "--tag", "seed"]}
    ],
    "checks": {
      "step_json_tags": {"3": {"expected_counts": {"seed": 2}}},
      "step_json_graph": {"4": {"nodes": ["n1-root.md", "n2-branch.md"], "edges": [["n1-root.md", "n2-branch.md"]]}}
    }
  },
  {
    "id": "ZKS002",
    "layer": "system",
    "system_dimension": "boundary_crossing",
    "category": "tag_graph_filter",
    "requirement_refs": ["REQ-tags", "REQ-list-filters", "REQ-graph"],
    "description": "Frontmatter, hashtags, colon tags, OR/NOT filters, and graph filtering compose.",
    "weight": 8,
    "setup_files": {
      "{nb}/.zk/config.toml": "[format.markdown]\ncolon_tags = true\n",
      "{nb}/a.md": "---\ntags: [inbox]\n---\n# A\n#todo :project/ai: [[B]]\n",
      "{nb}/b.md": "# B\n#later\n",
      "{nb}/c.md": "# C\n#done #inbox\n"
    },
    "steps": [
      {"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--tag", "inbox OR later, NOT done"]},
      {"args": ["--notebook-dir", "{nb}", "graph", "--format", "json", "--tag", "inbox OR later, NOT done"]}
    ],
    "checks": {
      "step_stdout_contains": {"0": ["a.md", "b.md"]},
      "step_stdout_forbidden": {"0": ["c.md"]},
      "step_json_graph": {"1": {"nodes": ["a.md", "b.md"], "edges": [["a.md", "b.md"]]}}
    }
  },
  {
    "id": "ZKS003",
    "layer": "system",
    "system_dimension": "global_invariant",
    "category": "link_graph_invariants",
    "requirement_refs": ["REQ-links", "REQ-list-filters", "REQ-graph"],
    "description": "Recursive links, orphan detection, and missing backlinks agree on the same graph.",
    "weight": 8,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/hub.md": "# Hub\n[[Leaf]]\n",
      "{nb}/leaf.md": "# Leaf\n[[Twig]]\n",
      "{nb}/twig.md": "# Twig\n",
      "{nb}/solo.md": "# Solo\n"
    },
    "steps": [
      {"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--linked-by", "hub.md", "--recursive", "--max-distance", "2"]},
      {"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--orphan"]},
      {"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--missing-backlink"]}
    ],
    "checks": {
      "step_stdout_contains": {"0": ["leaf.md", "twig.md"], "1": ["hub.md", "solo.md"], "2": ["leaf.md", "twig.md"]},
      "step_stdout_forbidden": {"0": ["solo.md"], "1": ["leaf.md", "twig.md"], "2": ["hub.md", "solo.md"]}
    }
  },
  {
    "id": "ZKS004",
    "layer": "system",
    "system_dimension": "state_accumulation",
    "category": "config_filter_links",
    "requirement_refs": ["REQ-config", "REQ-list-filters", "REQ-links"],
    "description": "Named config filters, excludes, and recursive links compose over notebook state.",
    "weight": 8,
    "setup_files": {
      "{nb}/.zk/config.toml": "[filter.work]\ntag = \"work\"\nexclude = \"archive\"\n",
      "{nb}/active.md": "# Active\n#work [[Child]]\n",
      "{nb}/child.md": "# Child\n#work\n",
      "{nb}/archive/old.md": "# Old\n#work\n",
      "{nb}/home.md": "# Home\n#personal\n"
    },
    "steps": [
      {"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--filter", "work"]},
      {"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--filter", "work", "--linked-by", "active.md", "--recursive"]}
    ],
    "checks": {
      "step_stdout_contains": {"0": ["active.md", "child.md"], "1": ["child.md"]},
      "step_stdout_forbidden": {"0": ["archive/old.md", "home.md"], "1": ["archive/old.md", "home.md", "active.md"]}
    }
  },
  {
    "id": "ZKS005",
    "layer": "system",
    "system_dimension": "boundary_crossing",
    "category": "sort_filters",
    "requirement_refs": ["REQ-new-note", "REQ-list-filters", "REQ-note-parse"],
    "description": "Created notes with different body sizes are filtered and sorted by word count descending.",
    "weight": 8,
    "steps": [
      {"args": ["init", "{nb}"]},
      {"args": ["--notebook-dir", "{nb}", "new", "--filename", "short.md", "--title", "Short", "--interactive"], "stdin": "# Short\n#draft one\n"},
      {"args": ["--notebook-dir", "{nb}", "new", "--filename", "long.md", "--title", "Long", "--interactive"], "stdin": "# Long\n#draft one two three four five\n"},
      {"args": ["--notebook-dir", "{nb}", "new", "--filename", "mid.md", "--title", "Mid", "--interactive"], "stdin": "# Mid\n#draft one two three\n"},
      {"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--tag", "draft", "--sort", "word-count-"]}
    ],
    "checks": {"step_stdout_contains": {"4": ["long.md", "mid.md", "short.md"]}, "stdout_order": ["long.md", "mid.md", "short.md"]}
  },
  {
    "id": "ZKS006",
    "layer": "system",
    "system_dimension": "error_atomicity",
    "category": "duplicate_graph_atomicity",
    "requirement_refs": ["REQ-new-note", "REQ-errors", "REQ-graph"],
    "description": "Duplicate note creation fails without corrupting existing graph state.",
    "weight": 8,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/root.md": "# Root\n[[Branch]]\n",
      "{nb}/branch.md": "# Branch\n"
    },
    "steps": [
      {"args": ["--notebook-dir", "{nb}", "new", "--filename", "root.md", "--title", "Replacement"], "allow_error": true},
      {"args": ["--notebook-dir", "{nb}", "graph", "--format", "json"]}
    ],
    "checks": {
      "step_expect_error": ["0"],
      "step_stderr_contains_any": {"0": ["exists", "duplicate", "overwrite"]},
      "step_json_graph": {"1": {"nodes": ["root.md", "branch.md"], "edges": [["root.md", "branch.md"]]}}
    }
  },
  {
    "id": "ZKS007",
    "layer": "system",
    "system_dimension": "cross_feature_dataflow",
    "category": "title_link_resolution",
    "requirement_refs": ["REQ-note-parse", "REQ-links", "REQ-graph"],
    "description": "Parsed titles feed wiki-link resolution and graph output.",
    "weight": 8,
    "setup_files": {
      "{nb}/.zk/config.toml": "",
      "{nb}/ideas/root.md": "# Root Idea\n[[Branch Idea]]\n",
      "{nb}/ideas/branch.md": "---\ntitle: Branch Idea\n---\nBody\n"
    },
    "steps": [
      {"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--linked-by", "ideas/root.md"]},
      {"args": ["--notebook-dir", "{nb}", "graph", "--format", "json"]}
    ],
    "checks": {
      "step_stdout_contains": {"0": ["ideas/branch.md"]},
      "step_json_graph": {"1": {"nodes": ["ideas/root.md", "ideas/branch.md"], "edges": [["ideas/root.md", "ideas/branch.md"]]}}
    }
  },
  {
    "id": "ZKS008",
    "layer": "system",
    "system_dimension": "global_invariant",
    "category": "tag_counts_sort",
    "requirement_refs": ["REQ-tags", "REQ-list-filters"],
    "description": "Tag counts and note-count descending sort reflect all parsed tag sources.",
    "weight": 8,
    "setup_files": {
      "{nb}/.zk/config.toml": "[format.markdown]\ncolon_tags = true\n",
      "{nb}/a.md": "---\nkeywords: [alpha]\n---\n# A\n#common :area/x:\n",
      "{nb}/b.md": "---\ntags: [beta]\n---\n# B\n#common\n",
      "{nb}/c.md": "# C\n#common\n"
    },
    "steps": [{"args": ["--notebook-dir", "{nb}", "tag", "list", "--format", "json", "--sort", "note-count-"]}],
    "checks": {"json_tags": {"expected_counts": {"common": 3, "alpha": 1, "beta": 1, "area/x": 1}}, "json_tags_order": ["common", "alpha", "area/x", "beta"]}
  },
  {
    "id": "ZKS009",
    "layer": "system",
    "system_dimension": "state_accumulation",
    "category": "notebook_precedence_filters",
    "requirement_refs": ["REQ-notebook", "REQ-config", "REQ-list-filters"],
    "description": "Notebook precedence and named filters select the correct persisted notebook state.",
    "weight": 8,
    "setup_files": {
      "{nb}/.zk/config.toml": "[filter.work]\ntag = \"work\"\n",
      "{nb}/a.md": "# Primary\n#work\n",
      "{other}/.zk/config.toml": "[filter.work]\ntag = \"work\"\n",
      "{other}/b.md": "# Other\n#work\n"
    },
    "steps": [
      {"args": ["list", "--format", "path", "--filter", "work"], "cwd": "{tmp}", "env": {"ZK_NOTEBOOK_DIR": "{other}"}},
      {"args": ["--notebook-dir", "{nb}", "list", "--format", "path", "--filter", "work"], "cwd": "{tmp}", "env": {"ZK_NOTEBOOK_DIR": "{other}"}}
    ],
    "checks": {
