[
  {
    "id": "SQU001",
    "layer": "unit",
    "category": "insert",
    "requirement_refs": ["REQ-import"],
    "description": "JSON insert creates a typed table with a single-column primary key.",
    "weight": 4,
    "setup_files": {
      "pets.json": "[{\"id\":1,\"name\":\"Cleo\",\"age\":4,\"weight\":12.5,\"good\":true,\"tags\":[\"cat\",\"tabby\"]},{\"id\":2,\"name\":\"Pancakes\",\"age\":2,\"weight\":8.0,\"good\":false,\"tags\":[\"dog\"]}]"
    },
    "commands": [["data.db", "insert", "pets", "pets.json", "--json", "--pk", "id"]],
    "checks": {
      "sql": {
        "select id, name, typeof(age), typeof(weight), good, tags from pets order by id": [
          [1, "Cleo", "integer", "real", 1, "[\"cat\",\"tabby\"]"],
          [2, "Pancakes", "integer", "real", 0, "[\"dog\"]"]
        ]
      }
    }
  },
  {
    "id": "SQU002",
    "layer": "unit",
    "category": "insert",
    "requirement_refs": ["REQ-import"],
    "description": "CSV insert infers integer, real, boolean, and text columns.",
    "weight": 4,
    "setup_files": {
      "inventory.csv": "id,name,qty,price,active,note\n1,Hammer,3,12.5,true,none\n2,Nail,40,0.1,false,small\n"
    },
    "commands": [["data.db", "insert", "inventory", "inventory.csv", "--csv", "--pk", "id"]],
    "checks": {
      "sql": {
        "select id, typeof(id), qty, typeof(qty), price, typeof(price), active, typeof(active), note from inventory order by id": [
          [1, "integer", 3, "integer", 12.5, "real", 1, "integer", "none"],
          [2, "integer", 40, "integer", 0.1, "real", 0, "integer", "small"]
        ]
      }
    }
  },
  {
    "id": "SQU003",
    "layer": "unit",
    "category": "upsert",
    "requirement_refs": ["REQ-upsert"],
    "description": "Upsert updates matching primary-key rows while preserving omitted old values.",
    "weight": 4,
    "setup_sql": [
      "create table dogs(id integer primary key, name text, age integer, breed text);",
      "insert into dogs(id,name,age,breed) values (1,'Cleo',4,'tabby'),(2,'Nixie',2,null);"
    ],
    "setup_files": {
      "updates.json": "[{\"id\":1,\"age\":5},{\"id\":3,\"name\":\"Marnie\",\"age\":1,\"breed\":\"mix\"}]"
    },
    "commands": [["data.db", "upsert", "dogs", "updates.json", "--json", "--pk", "id"]],
    "checks": {
      "sql": {
        "select id, name, age, breed from dogs order by id": [
          [1, "Cleo", 5, "tabby"],
          [2, "Nixie", 2, null],
          [3, "Marnie", 1, "mix"]
        ]
      }
    }
  },
  {
    "id": "SQU004",
    "layer": "unit",
    "category": "upsert",
    "requirement_refs": ["REQ-upsert"],
    "description": "Compound-key upsert with alter adds new columns and preserves omitted values.",
    "weight": 4,
    "setup_sql": [
      "create table scores(team text, week integer, score integer, note text, primary key(team, week));",
      "insert into scores(team,week,score,note) values ('red',1,10,'keep'),('red',2,11,'old'),('blue',1,7,'blue');"
    ],
    "setup_files": {
      "updates.json": "[{\"team\":\"red\",\"week\":1,\"score\":12,\"flag\":true},{\"team\":\"blue\",\"week\":2,\"score\":9,\"note\":\"new\",\"flag\":false}]"
    },
    "commands": [["data.db", "upsert", "scores", "updates.json", "--json", "--pk", "team,week", "--alter"]],
    "checks": {
      "sql": {
        "select team, week, score, note, flag from scores order by team, week": [
          ["blue", 1, 7, "blue", null],
          ["blue", 2, 9, "new", 0],
          ["red", 1, 12, "keep", 1],
          ["red", 2, 11, "old", null]
        ]
      }
    }
  },
  {
    "id": "SQU005",
    "layer": "unit",
    "category": "query",
    "requirement_refs": ["REQ-query"],
    "description": "Rows command applies where, order, and limit to an existing table.",
    "weight": 4,
    "setup_sql": [
      "create table pets(id integer primary key, name text, age integer);",
      "insert into pets(id,name,age) values (1,'Cleo',4),(2,'Pancakes',2),(3,'Miso',7);"
    ],
    "commands": [["data.db", "rows", "pets", "--where", "age >= 3", "--order", "age desc", "--limit", "2"]],
    "checks": {
      "stdout_json": {
        "0": [
          {"id": 3, "name": "Miso", "age": 7},
          {"id": 1, "name": "Cleo", "age": 4}
        ]
      }
    }
  },
  {
    "id": "SQU006",
    "layer": "unit",
    "category": "query",
    "requirement_refs": ["REQ-query"],
    "description": "Query command returns JSON row objects for arbitrary SQL.",
    "weight": 4,
    "setup_sql": [
      "create table pets(id integer primary key, name text, age integer);",
      "insert into pets(id,name,age) values (1,'Cleo',4),(2,'Pancakes',2),(3,'Miso',7);"
    ],
    "commands": [["data.db", "query", "select name, age from pets where age > 3 order by name"]],
    "checks": {
      "stdout_json": {
        "0": [
          {"name": "Cleo", "age": 4},
          {"name": "Miso", "age": 7}
        ]
      }
    }
  },
  {
    "id": "SQU007",
    "layer": "unit",
    "category": "metadata",
    "requirement_refs": ["REQ-query"],
    "description": "Tables with counts and schema reflect existing database metadata.",
    "weight": 4,
    "setup_sql": [
      "create table pets(id integer primary key, name text);",
      "insert into pets(id,name) values (1,'Cleo'),(2,'Miso');"
    ],
    "commands": [
      ["data.db", "tables", "--counts"],
      ["data.db", "schema", "pets"]
    ],
    "checks": {
      "stdout_json_contains": {
        "0": [{"table": "pets", "count": 2}]
      },
      "stdout_contains": {
        "1": ["CREATE TABLE", "pets", "id", "name"]
      }
    }
  },
  {
    "id": "SQU008",
    "layer": "unit",
    "category": "extract",
    "requirement_refs": ["REQ-extract"],
    "description": "Extract normalizes repeated text values into a lookup table.",
    "weight": 4,
    "setup_sql": [
      "create table orders(id integer primary key, customer text, total integer);",
      "insert into orders(id,customer,total) values (1,'Ada',10),(2,'Lin',15),(3,'Ada',7);"
    ],
    "commands": [["data.db", "extract", "orders", "customer", "customers"]],
    "checks": {
      "sql": {
        "select id, value from customers order by id": [[1, "Ada"], [2, "Lin"]],
        "select id, customer_id, total from orders order by id": [[1, 1, 10], [2, 2, 15], [3, 1, 7]]
      }
    }
  },
  {
    "id": "SQU009",
    "layer": "unit",
    "category": "extract",
    "requirement_refs": ["REQ-extract"],
    "description": "Extract ignores null values and assigns lookup IDs in first-seen order.",
    "weight": 4,
    "setup_sql": [
      "create table events(id integer primary key, kind text);",
      "insert into events(id,kind) values (1,'beta'),(2,null),(3,'alpha'),(4,'beta');"
    ],
    "commands": [["data.db", "extract", "events", "kind", "kinds"]],
    "checks": {
      "sql": {
        "select id, value from kinds order by id": [[1, "beta"], [2, "alpha"]],
        "select id, kind_id from events order by id": [[1, 1], [2, null], [3, 2], [4, 1]]
      }
    }
  },
  {
    "id": "SQU010",
    "layer": "unit",
    "category": "fts",
    "requirement_refs": ["REQ-fts"],
    "description": "Enable-FTS builds an FTS table for an existing document table.",
    "weight": 4,
    "setup_sql": [
      "create table docs(id integer primary key, title text, body text);",
      "insert into docs(id,title,body) values (1,'Alpha','red apple harvest'),(2,'Beta','green pear orchard');"
    ],
    "commands": [["data.db", "enable-fts", "docs", "title", "body"]],
    "checks": {
      "sql": {
        "select count(*) from docs_fts": [[2]]
      }
    }
  },
  {
    "id": "SQU011",
    "layer": "unit",
    "category": "fts",
    "requirement_refs": ["REQ-fts"],
    "description": "Search returns original rows from an existing FTS index.",
    "weight": 4,
    "setup_sql": [
      "create table docs(id integer primary key, title text, body text);",
      "insert into docs(id,title,body) values (1,'Alpha','red apple harvest'),(2,'Beta','green pear orchard');",
      "create virtual table docs_fts using fts5(title, body, content='docs', content_rowid='id');",
      "insert into docs_fts(rowid,title,body) values (1,'Alpha','red apple harvest'),(2,'Beta','green pear orchard');"
    ],
    "commands": [["data.db", "search", "docs", "apple", "--limit", "5"]],
    "checks": {
      "stdout_json_contains": {
        "0": [{"id": 1, "title": "Alpha", "body": "red apple harvest"}]
      }
    }
  },
  {
    "id": "SQU012",
    "layer": "unit",
    "category": "transform",
    "requirement_refs": ["REQ-transform"],
    "description": "Transform renames, drops, and adds JSON-parsed default columns.",
    "weight": 4,
    "setup_sql": [
      "create table tasks(id integer primary key, name text, scratch text);",
      "insert into tasks(id,name,scratch) values (1,'One','x'),(2,'Two','y');"
    ],
    "commands": [["data.db", "transform", "tasks", "--rename", "name:title", "--drop", "scratch", "--default", "priority=1", "--default", "done=false"]],
    "checks": {
      "sql": {
        "select id, title, priority, typeof(priority), done, typeof(done) from tasks order by id": [
          [1, "One", 1, "integer", 0, "integer"],
          [2, "Two", 1, "integer", 0, "integer"]
        ]
      }
    }
  },
  {
    "id": "SQU013",
    "layer": "unit",
    "category": "transform",
    "requirement_refs": ["REQ-transform", "REQ-atomic"],
    "description": "Invalid not-null transform fails without changing table rows.",
    "weight": 4,
    "setup_sql": [
      "create table items(id integer primary key, name text, code text);",
      "insert into items(id,name,code) values (1,'A',null),(2,'B','b');"
    ],
    "commands": [{"args": ["data.db", "transform", "items", "--not-null", "code"], "expect_error": true}],
    "checks": {
      "sql": {
        "select id, name, code from items order by id": [[1, "A", null], [2, "B", "b"]],
        "select name from pragma_table_info('items') order by cid": [["id"], ["name"], ["code"]]
      }
    }
  },
  {
    "id": "SQU014",
    "layer": "unit",
    "category": "error_atomicity",
    "requirement_refs": ["REQ-import", "REQ-atomic"],
    "description": "Insert with unknown columns fails without --alter and preserves existing rows.",
    "weight": 4,
    "setup_sql": [
      "create table dogs(id integer primary key, name text);",
      "insert into dogs(id,name) values (1,'Cleo');"
    ],
    "setup_files": {
      "incoming.json": "[{\"id\":2,\"name\":\"Miso\",\"breed\":\"tabby\"}]"
    },
    "commands": [{"args": ["data.db", "insert", "dogs", "incoming.json", "--json", "--pk", "id"], "expect_error": true}],
    "checks": {
      "sql": {
        "select id, name from dogs order by id": [[1, "Cleo"]]
      }
    }
  },
  {
    "id": "SQU015",
    "layer": "unit",
    "category": "error_atomicity",
    "requirement_refs": ["REQ-import", "REQ-atomic"],
    "description": "Invalid JSON import fails nonzero.",
    "weight": 4,
    "setup_files": {
      "bad.json": "[{\"id\":1,\"name\":\"A\"}"
    },
    "commands": [{"args": ["data.db", "insert", "bad", "bad.json", "--json", "--pk", "id"], "expect_error": true}],
    "checks": {}
  },
  {
    "id": "SQU016",
    "layer": "unit",
    "category": "query",
    "requirement_refs": ["REQ-query"],
    "description": "Rows command returns an empty JSON list when no rows match.",
    "weight": 4,
    "setup_sql": [
      "create table pets(id integer primary key, name text, age integer);",
      "insert into pets(id,name,age) values (1,'Cleo',4),(2,'Pancakes',2);"
    ],
    "commands": [["data.db", "rows", "pets", "--where", "age > 10", "--order", "id"]],
    "checks": {
      "stdout_json": {
        "0": []
      }
    }
  },
  {
    "id": "SQS001",
    "layer": "system",
    "system_dimension": "cross_feature_dataflow",
    "category": "insert_upsert_query",
    "requirement_refs": ["REQ-import", "REQ-upsert", "REQ-query"],
    "description": "CSV type inference flows through upsert-alter and rows/query output.",
    "weight": 8,
    "setup_files": {
      "inventory.csv": "id,name,qty,price,active,note\n1,Hammer,3,12.5,true,none\n2,Nail,40,0.1,false,small\n",
      "updates.json": "[{\"id\":1,\"qty\":4,\"tag\":\"tool\"},{\"id\":3,\"name\":\"Saw\",\"qty\":2,\"price\":5.5,\"active\":true,\"note\":\"new\",\"tag\":\"cut\"}]"
    },
    "commands": [
      ["data.db", "insert", "inventory", "inventory.csv", "--csv", "--pk", "id"],
      ["data.db", "upsert", "inventory", "updates.json", "--json", "--pk", "id", "--alter"],
      ["data.db", "rows", "inventory", "--where", "active = 1", "--order", "id"]
    ],
    "checks": {
      "stdout_json": {
        "2": [
          {"id": 1, "name": "Hammer", "qty": 4, "price": 12.5, "active": 1, "note": "none", "tag": "tool"},
          {"id": 3, "name": "Saw", "qty": 2, "price": 5.5, "active": 1, "note": "new", "tag": "cut"}
        ]
      },
      "sql": {
        "select id, typeof(qty), typeof(price), typeof(active), note, tag from inventory order by id": [
          [1, "integer", "real", "integer", "none", "tool"],
          [2, "integer", "real", "integer", "small", null],
          [3, "integer", "real", "integer", "new", "cut"]
        ]
      }
    }
  },
  {
    "id": "SQS002",
    "layer": "system",
    "system_dimension": "state_accumulation",
    "category": "extract_transform_query",
    "requirement_refs": ["REQ-import", "REQ-extract", "REQ-transform", "REQ-query"],
    "description": "Inserted rows are normalized, transformed, and queried without losing lookup relationships.",
    "weight": 8,
    "setup_files": {
      "orders.json": "[{\"id\":1,\"customer\":\"Ada\",\"total\":10,\"scratch\":\"x\"},{\"id\":2,\"customer\":\"Lin\",\"total\":15,\"scratch\":\"y\"},{\"id\":3,\"customer\":\"Ada\",\"total\":7,\"scratch\":\"z\"}]"
    },
    "commands": [
      ["data.db", "insert", "orders", "orders.json", "--json", "--pk", "id"],
      ["data.db", "extract", "orders", "customer", "customers"],
      ["data.db", "transform", "orders", "--rename", "total:amount", "--drop", "scratch", "--default", "status=open"],
      ["data.db", "query", "select o.id, c.value as customer, o.amount, o.status from orders o join customers c on o.customer_id = c.id order by o.id"]
    ],
    "checks": {
      "stdout_json": {
        "3": [
          {"id": 1, "customer": "Ada", "amount": 10, "status": "open"},
          {"id": 2, "customer": "Lin", "amount": 15, "status": "open"},
          {"id": 3, "customer": "Ada", "amount": 7, "status": "open"}
        ]
      },
      "sql": {
        "select id, value from customers order by id": [[1, "Ada"], [2, "Lin"]]
      }
    }
  },
  {
    "id": "SQS003",
    "layer": "system",
    "system_dimension": "state_accumulation",
    "category": "fts_rebuild",
    "requirement_refs": ["REQ-import", "REQ-upsert", "REQ-fts", "REQ-query"],
    "description": "FTS rebuild after upsert reflects updated original rows.",
    "weight": 8,
    "setup_files": {
      "docs.json": "[{\"id\":1,\"title\":\"One\",\"body\":\"alpha apple\"},{\"id\":2,\"title\":\"Two\",\"body\":\"banana pear\"}]",
      "updates.json": "[{\"id\":2,\"body\":\"banana apple updated\"}]"
    },
    "commands": [
      ["data.db", "insert", "docs", "docs.json", "--json", "--pk", "id"],
      ["data.db", "enable-fts", "docs", "title", "body"],
      ["data.db", "upsert", "docs", "updates.json", "--json", "--pk", "id"],
      ["data.db", "enable-fts", "docs", "title", "body"],
      ["data.db", "search", "docs", "updated", "--limit", "2"]
    ],
    "checks": {
      "stdout_json_contains": {
        "4": [{"id": 2, "title": "Two", "body": "banana apple updated"}]
      },
      "sql": {
        "select count(*) from docs_fts": [[2]]
      }
    }
  },
  {
    "id": "SQS004",
    "layer": "system",
    "system_dimension": "global_invariant",
    "category": "schema_metadata",
    "requirement_refs": ["REQ-import", "REQ-transform", "REQ-query"],
    "description": "Transform preserves primary key, row count, metadata, and query behavior.",
    "weight": 8,
    "setup_files": {
      "items.json": "[{\"id\":1,\"name\":\"Hammer\",\"notes\":\"old\"},{\"id\":2,\"name\":\"Nail\",\"notes\":\"tiny\"}]"
    },
    "commands": [
      ["data.db", "insert", "items", "items.json", "--json", "--pk", "id"],
      ["data.db", "transform", "items", "--rename", "name:title", "--drop", "notes", "--default", "status=active"],
      ["data.db", "tables", "--counts"],
      ["data.db", "schema", "items"],
      ["data.db", "rows", "items", "--order", "id"]
    ],
    "checks": {
      "stdout_json_contains": {
        "2": [{"table": "items", "count": 2}]
      },
      "stdout_contains": {
        "3": ["PRIMARY KEY", "title", "status"]
      },
      "stdout_json": {
        "4": [
          {"id": 1, "title": "Hammer", "status": "active"},
          {"id": 2, "title": "Nail", "status": "active"}
        ]
      }
    }
  },
  {
    "id": "SQS005",
    "layer": "system",
    "system_dimension": "error_atomicity",
    "category": "transform_atomicity_after_extract",
    "requirement_refs": ["REQ-import", "REQ-extract", "REQ-transform", "REQ-atomic"],
    "description": "Invalid transform after extract leaves original table and lookup table intact.",
    "weight": 8,
    "setup_files": {
      "orders.json": "[{\"id\":1,\"customer\":\"Ada\",\"total\":10},{\"id\":2,\"customer\":\"Lin\",\"total\":15}]"
    },
    "commands": [
      ["data.db", "insert", "orders", "orders.json", "--json", "--pk", "id"],
      ["data.db", "extract", "orders", "customer", "customers"],
      {"args": ["data.db", "transform", "orders", "--drop", "missing"], "expect_error": true}
    ],
    "checks": {
      "sql": {
        "select id, customer_id, total from orders order by id": [[1, 1, 10], [2, 2, 15]],
        "select id, value from customers order by id": [[1, "Ada"], [2, "Lin"]],
        "select name from pragma_table_info('orders') order by cid": [["id"], ["customer_id"], ["total"]]
      }
    }
  },
  {
    "id": "SQS006",
    "layer": "system",
    "system_dimension": "error_atomicity",
    "category": "upsert_atomicity",
    "requirement_refs": ["REQ-import", "REQ-upsert", "REQ-query", "REQ-atomic"],
    "description": "Upsert with unknown columns and no alter fails without corrupting queryable rows.",
    "weight": 8,
    "setup_files": {
      "base.json": "[{\"id\":1,\"name\":\"Cleo\"},{\"id\":2,\"name\":\"Miso\"}]",
      "bad.json": "[{\"id\":2,\"name\":\"Miso\",\"breed\":\"tabby\"}]"
    },
    "commands": [
      ["data.db", "insert", "dogs", "base.json", "--json", "--pk", "id"],
      {"args": ["data.db", "upsert", "dogs", "bad.json", "--json", "--pk", "id"], "expect_error": true},
      ["data.db", "rows", "dogs", "--order", "id"]
    ],
    "checks": {
      "stdout_json": {
        "2": [
          {"id": 1, "name": "Cleo"},
          {"id": 2, "name": "Miso"}
        ]
      },
      "sql": {
        "select name from pragma_table_info('dogs') order by cid": [["id"], ["name"]]
      }
    }
  },
  {
    "id": "SQS007",
    "layer": "system",
    "system_dimension": "boundary_crossing",
    "category": "compound_transform",
    "requirement_refs": ["REQ-import", "REQ-upsert", "REQ-transform"],
    "description": "Compound-key upsert output survives transform defaults and dropped columns.",
    "weight": 8,
    "setup_files": {
      "base.json": "[{\"team\":\"red\",\"week\":1,\"score\":10,\"note\":\"keep\"},{\"team\":\"red\",\"week\":2,\"score\":11,\"note\":\"old\"},{\"team\":\"blue\",\"week\":1,\"score\":7,\"note\":\"blue\"}]",
      "updates.json": "[{\"team\":\"red\",\"week\":1,\"score\":12,\"flag\":true},{\"team\":\"blue\",\"week\":2,\"score\":9,\"note\":\"new\",\"flag\":false}]"
    },
    "commands": [
      ["data.db", "insert", "scores", "base.json", "--json", "--pk", "team,week"],
      ["data.db", "upsert", "scores", "updates.json", "--json", "--pk", "team,week", "--alter"],
      ["data.db", "transform", "scores", "--drop", "note", "--default", "reviewed=false"]
    ],
    "checks": {
      "sql": {
        "select team, week, score, flag, reviewed from scores order by team, week": [
          ["blue", 1, 7, null, 0],
          ["blue", 2, 9, 0, 0],
          ["red", 1, 12, 1, 0],
          ["red", 2, 11, null, 0]
        ]
      }
    }
  },
  {
    "id": "SQS008",
    "layer": "system",
    "system_dimension": "cross_feature_dataflow",
    "category": "extract_to_fts",
    "requirement_refs": ["REQ-import", "REQ-extract", "REQ-fts", "REQ-query"],
    "description": "Extracted lookup table can become an FTS source and return lookup rows.",
    "weight": 8,
    "setup_files": {
      "posts.json": "[{\"id\":1,\"topic\":\"apple pie\",\"body\":\"a\"},{\"id\":2,\"topic\":\"pear tart\",\"body\":\"b\"},{\"id\":3,\"topic\":\"apple pie\",\"body\":\"c\"}]"
    },
    "commands": [
      ["data.db", "insert", "posts", "posts.json", "--json", "--pk", "id"],
      ["data.db", "extract", "posts", "topic", "topics"],
      ["data.db", "enable-fts", "topics", "value"],
      ["data.db", "search", "topics", "apple", "--limit", "5"]
    ],
    "checks": {
      "stdout_json_contains": {
        "3": [{"id": 1, "value": "apple pie"}]
      },
      "sql": {
        "select topic_id, count(*) from posts group by topic_id order by topic_id": [[1, 2], [2, 1]]
      }
    }
  },
  {
    "id": "SQS009",
    "layer": "system",
    "system_dimension": "global_invariant",
    "category": "multi_table_invariant",
    "requirement_refs": ["REQ-import", "REQ-transform", "REQ-query"],
    "description": "Transforming one table does not alter unrelated tables or metadata counts.",
    "weight": 8,
    "setup_files": {
      "items.json": "[{\"id\":1,\"name\":\"Hammer\",\"category_id\":1},{\"id\":2,\"name\":\"Nail\",\"category_id\":1}]",
      "categories.json": "[{\"id\":1,\"name\":\"Tools\"}]"
